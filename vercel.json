{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/hms/",
      "destination": "/apps/hms/",
      "permanent": true
    },
    {
      "source": "/inventory/",
      "destination": "/apps/inventory/",
      "permanent": true
    },
    {
      "source": "/asset/",
      "destination": "/apps/asset/",
      "permanent": true
    },
    {
      "source": "/ot-room/",
      "destination": "/apps/ot-room/",
      "permanent": true
    },
    {
      "source": "/finance/",
      "destination": "/apps/finance/",
      "permanent": true
    },
    {
      "source": "/pharmacy/",
      "destination": "/apps/pharmacy/",
      "permanent": true
    },
    {
      "source": "/lab/",
      "destination": "/apps/lab/",
      "permanent": true
    },
    {
      "source": "/people/",
      "destination": "/apps/people/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
