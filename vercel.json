    {
      "source": "/ot-room",
      "destination": "/apps/ot-room/",
      "permanent": true
    },
    {
      "source": "/finance",
      "destination": "/apps/finance/",
      "permanent": true
    },
    {
      "source": "/pharmacy",
      "destination": "/apps/pharmacy/",
      "permanent": true
    },
    {
      "source": "/lab",
      "destination": "/apps/lab/",
      "permanent": true
    },
    {
      "source": "/people",
      "destination": "/apps/people/",
      "permanent": true
    },
    {
      "source": "/solutions.html",
      "destination": "/solutions/",
      "permanent": true
    },
    {
      "source": "/customers.html",
      "destination": "/customers/",
      "permanent": true
    },
    {
      "source": "/resources.html",
      "destination": "/resources/",
