    },
    {
      "source": "/about-us.html",
      "destination": "/about-us/",
      "permanent": true
    },
    {
      "source": "/contact-us.html",
      "destination": "/contact-us/",
      "permanent": true
    },
    {
      "source": "/blog.html",
      "destination": "/blog/",
      "permanent": true
    },
    {
      "source": "/partners.html",
      "destination": "/partners/",
